{
  "realm": "erp",
  "enabled": true,
  "displayName": "ERP Institutional Realm",
  "sslRequired": "none",
  "accessTokenLifespan": 600,
  "ssoSessionIdleTimeout": 28800,
  "ssoSessionMaxLifespan": 43200,
  "revokeRefreshToken": true,
  "refreshTokenMaxReuse": 0,
  "attributes": {
    "frontendUrl": "__KEYCLOAK_PUBLIC_URL__"
  },
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "rememberMe": false,
  "roles": {
    "realm": [
      { "name": "ADMIN" },
      { "name": "USER" },
      { "name": "OIC.READONLY" },
      { "name": "OPS.CONSULTAR" },
      { "name": "EXPEDIENTE.CREAR" },
      { "name": "EXPEDIENTE.CONSULTAR" },
      { "name": "EXPEDIENTE.ACTUALIZAR" },
      { "name": "INVESTIGACION.CREAR" },
      { "name": "INVESTIGACION.CONSULTAR" },
      { "name": "NECESIDAD.CREAR" },
      { "name": "NECESIDAD.CONSULTAR" },
      { "name": "PROCEDIMIENTO.CREAR" },
      { "name": "PROCEDIMIENTO.CONSULTAR" },
      { "name": "PROCEDIMIENTO.ACTUALIZAR" },
      { "name": "CUADRO_COMPARATIVO.CONSULTAR" },
      { "name": "CONTRATO.CREAR" },
      { "name": "CONTRATO.CONSULTAR" },
      { "name": "CONTRATO.ADJUNTAR_DOCUMENTO" },
      { "name": "ORDEN.CREAR" },
      { "name": "ORDEN.CONSULTAR" },
      { "name": "ORDEN.ACTUALIZAR" },
      { "name": "RECEPCION.CREAR" },
      { "name": "RECEPCION.CONSULTAR" },
      { "name": "RECEPCION.ACTUALIZAR" },
      { "name": "DOCUMENTO.SUBIR" },
      { "name": "DOCUMENTO.DESCARGAR" },
      { "name": "INVENTARIO.CONSULTAR" },
      { "name": "INVENTARIO.AJUSTAR" },
      { "name": "INVENTARIO.CONTEO" },
      { "name": "PRODUCTO.CONSULTAR" },
      { "name": "PRODUCTO.CREAR" },
      { "name": "PRODUCTO.ACTUALIZAR" },
      { "name": "PROVEEDOR.CONSULTAR" },
      { "name": "PROVEEDOR.CREAR" },
      { "name": "PROVEEDOR.ACTUALIZAR" },
      { "name": "CONFIGURACION.CONSULTAR" },
      { "name": "FINANCIERO.CONSULTAR" },
      { "name": "PATRIMONIAL.CONSULTAR" },
      { "name": "PATRIMONIAL.OPERAR" }
    ]
  },
  "clients": [
    {
      "clientId": "erp-api",
      "name": "ERP API",
      "protocol": "openid-connect",
      "enabled": true,
      "publicClient": false,
      "secret": "__KEYCLOAK_API_CLIENT_SECRET__",
      "serviceAccountsEnabled": true,
      "directAccessGrantsEnabled": __KEYCLOAK_API_DIRECT_GRANTS__,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "fullScopeAllowed": false,
      "attributes": {
        "access.token.lifespan": "600"
      },
      "protocolMappers": [
        {
          "name": "audience-erp-api",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "erp-api",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        },
        {
          "name": "audience-account",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "account",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        },
        {
          "name": "realm-roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "userinfo.token.claim": "false",
            "id.token.claim": "false",
            "access.token.claim": "true",
            "claim.name": "realm_access.roles",
            "jsonType.label": "String"
          }
        }
      ]
    },
    {
      "clientId": "erp-backend",
      "name": "ERP Backend",
      "protocol": "openid-connect",
      "enabled": true,
      "publicClient": false,
      "secret": "__KEYCLOAK_BACKEND_CLIENT_SECRET__",
      "serviceAccountsEnabled": true,
      "directAccessGrantsEnabled": false,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "fullScopeAllowed": false,
      "attributes": {
        "access.token.lifespan": "600"
      }
    },
    {
      "clientId": "erp-frontend",
      "name": "ERP Frontend",
      "protocol": "openid-connect",
      "enabled": true,
      "publicClient": true,
      "serviceAccountsEnabled": false,
      "directAccessGrantsEnabled": false,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "fullScopeAllowed": true,
      "redirectUris": ["__APP_URL__/*", "https://*.erp.gob.local/*"],
      "webOrigins": ["__APP_URL__", "https://*.erp.gob.local"],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "__APP_URL__/* https://*.erp.gob.local/*"
      },
      "protocolMappers": [
        {
          "name": "audience-erp-api",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "erp-api",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "frontend.tester",
      "enabled": true,
      "email": "frontend.tester@erp.gob.local",
      "emailVerified": true,
      "firstName": "Frontend",
      "lastName": "Tester",
      "requiredActions": [],
      "credentials": [{ "type": "password", "value": "__TESTER_PASSWORD__", "temporary": false }],
      "realmRoles": [
        "ADMIN",
        "OPS.CONSULTAR",
        "USER",
        "CONFIGURACION.CONSULTAR",
        "FINANCIERO.CONSULTAR",
        "EXPEDIENTE.CREAR",
